# Скопируйте в файл .env в корне проекта и подставьте свой ключ.
# Файл .env в git не коммитьте.

# --- Обязательно для GigaChat (чат + эмбеддинги) ---
# Ключ из личного кабинета GigaChat («Данные для авторизации»).
GIGACHAT_CREDENTIALS=вставьте_ваш_ключ_сюда

# --- Чат (сопоставление сложных позиций через нейросеть) ---
# Lite часто кончается первым; при подписке Pro/Max укажите одну из моделей:
GIGACHAT_MODEL=GigaChat-Pro
# GIGACHAT_MODEL=GigaChat-Max

# --- Эмбеддинги (похожесть строк для исправлений из истории) ---
# Явно через API GigaChat, модель Embeddings (отдельный пакет/лимит в кабинете):
EMBEDDINGS_PROVIDER=gigachat
GIGACHAT_EMBEDDINGS_MODEL=Embeddings

# Сколько строк за один запрос к Embeddings API (меньше — стабильнее при лимитах; больше — быстрее).
# EMBEDDINGS_BATCH_SIZE=32

# Если эмбеддинги хотите считать на своём ПК без списания Embeddings API:
# EMBEDDINGS_PROVIDER=local

# --- Порт приложения (на macOS 5000 часто занят AirPlay) ---
PORT=5001

# --- Альтернатива ключу: Client ID + Authorization Key (вместо GIGACHAT_CREDENTIALS) ---
# GIGACHAT_CLIENT_ID=
# GIGACHAT_AUTH_KEY=
